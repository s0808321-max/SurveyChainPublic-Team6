# JWT（建議本地測試也設定；未設時後端使用開發預設密鑰）
# JWT_SECRET=local-dev-jwt-secret

# CORS：若前端非 localhost:5173，可設定（選用）
# FRONTEND_URL=http://localhost:5173

# PostgreSQL 資料庫設定
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_NAME=web3survey
DB_SSLMODE=disable

# 若使用雲端 PostgreSQL（如 Supabase、Railway），可改用完整連線字串
# DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require
