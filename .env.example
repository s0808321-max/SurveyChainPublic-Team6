# ── Railway 部署必填 ──────────────────────────────────────────────────────────

# Railway PostgreSQL 外掛會自動注入 DATABASE_URL，不需要手動填寫
# 若自架資料庫則填寫下方個別欄位
# DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# JWT 簽名密鑰（必填，建議用 openssl rand -hex 32 產生）
JWT_SECRET=71283b56eadfc940

# 前端部署網址（必填，用於 CORS 白名單）
# 例如 Railway 前端服務的網址：https://your-frontend.up.railway.app
FRONTEND_URL=https://surveychainpublic-team6-production.up.railway.app/

# ── 本機開發（DATABASE_URL 未設時才會讀這些） ────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_NAME=web3survey
DB_SSLMODE=disable
