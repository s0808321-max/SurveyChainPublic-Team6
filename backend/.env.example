# ════════════════════════════════════════════════════════
# Railway 部署所需環境變數
# ════════════════════════════════════════════════════════

# JWT 簽名密鑰（必填，請設定為隨機長字串）
JWT_SECRET=your-super-secret-jwt-key-min-32-chars

# ─── 資料庫設定 ───────────────────────────────────────
# 方法 1（推薦）：使用 Railway PostgreSQL 提供的完整連線字串
# Railway 會自動注入此變數，通常不需要手動設定
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# 方法 2：分散設定（擇一即可）
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=your_password_here
# DB_NAME=web3survey
# DB_SSLMODE=require

# ─── PORT（Railway 自動注入，不需手動設定）────────────
# PORT=8080
